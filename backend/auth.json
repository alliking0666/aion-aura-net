{
  "auth": {
    "telegramAuth": {
      "enabled": true,
      "required": true
    },
    "anonymousMode": {
      "enabled": true,
      "generateTemporarySession": true
    },
    "storeUserData": false,
    "storePasswords": false,
    "jwtPlanned": true,
    "session": {
      "temporary": true,
      "expireAfterMinutes": 120
    }
  }
}